# ملف: _headers (النسخة المحسّنة - ضعه في جذر المستودع)

# قواعد عامة للموقع ككل (الأمان)
/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Robots-Tag: all

# قواعد خاصة لمجلد الصور - تخزين مؤقت طويل (سنة)
/images/*
  Cache-Control: max-age=31536000, public, immutable
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

# قواعد خاصة لملفات CSS و JavaScript (إن وجدت)
/css/*
  Cache-Control: max-age=31536000, public, immutable
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

/js/*
  Cache-Control: max-age=31536000, public, immutable
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

# قواعد خاصة لصفحات HTML - لا تخزن أو أعد التحقق دائماً
/*.html
  Cache-Control: no-cache
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Robots-Tag: all

# قواعد خاصة للصفحات الرئيسية (بدون امتداد)
/about
  Cache-Control: no-cache
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Robots-Tag: all

/
  Cache-Control: no-cache
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Robots-Tag: all
